  },
  {
    name: "Linear",
    formula: "f(z) = z",
    range: "(-∞, ∞)",
    category: "classic",
    use: "Regression output",
    desc: "No nonlinearity — used only in output layer for regression tasks. Stacking linear layers is still linear.",
    color: "#95a5a6",
    fn: z => z
  },
  // ReLU family
  {
    name: "ReLU",
    formula: "f(z) = max(0, z)",
    range: "[0, ∞)",
    category: "relu",
    use: "Default hidden layer choice",
    desc: "Fast, simple, widely used. Can suffer from dying ReLU — neurons permanently output 0 if weights go negative.",
    color: "#e67e22",
    fn: z => Math.max(0, z)
  },
  {
    name: "Leaky ReLU",
    formula: "f(z) = z if z>0 else 0.01z",
    range: "(-∞, ∞)",
    category: "relu",
    use: "Fix for dying ReLU",
    desc: "Small negative slope (0.01) keeps neurons alive. Simple fix for the dying ReLU problem.",
    color: "#d35400",
    fn: z => z > 0 ? z : 0.01 * z
  },
  {
    name: "PReLU",
    formula: "f(z) = z if z>0 else αz",
    range: "(-∞, ∞)",
    category: "relu",
    use: "When α should be learned",
    desc: "Like Leaky ReLU but α is a learnable parameter. More flexible, slightly more computation.",
    color: "#e74c3c",
    fn: z => z > 0 ? z : 0.05 * z  // α=0.05 for display
  },
  {
    name: "ELU",
    formula: "f(z) = z if z>0 else α(eᶻ−1)",
    range: "(-α, ∞)",
    category: "relu",
    use: "Smooth hidden layers",
    desc: "Smooth negative side, zero-centered outputs. Better gradient flow than ReLU. Slower to compute.",
    color: "#c0392b",
    fn: z => z > 0 ? z : 1.0 * (Math.exp(z) - 1)
  },
  {
    name: "SELU",
    formula: "f(z) = λ·ELU(z, α)",
    range: "(-λα, ∞)",
