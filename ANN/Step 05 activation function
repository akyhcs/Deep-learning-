function drawCurve(canvas, fn, color) {
  const dpr = window.devicePixelRatio || 1;
  const w = canvas.offsetWidth, h = canvas.offsetHeight;
  canvas.width = w * dpr;
  canvas.height = h * dpr;
  const ctx = canvas.getContext('2d');
  ctx.scale(dpr, dpr);

  const xMin = -4, xMax = 4;
  const yMin = -1.5, yMax = 1.5;

  const toX = v => ((v - xMin) / (xMax - xMin)) * w;
  const toY = v => h - ((v - yMin) / (yMax - yMin)) * h;

  // Grid
  ctx.strokeStyle = '#ede9e3';
  ctx.lineWidth = 1;
  [-1, 0, 1].forEach(v => {
    ctx.beginPath(); ctx.moveTo(0, toY(v)); ctx.lineTo(w, toY(v)); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(toX(v*2), 0); ctx.lineTo(toX(v*2), h); ctx.stroke();
  });

  // Axes
  ctx.strokeStyle = '#c8c2ba';
  ctx.lineWidth = 1;
  ctx.beginPath(); ctx.moveTo(0, toY(0)); ctx.lineTo(w, toY(0)); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(toX(0), 0); ctx.lineTo(toX(0), h); ctx.stroke();

  // Curve
  ctx.strokeStyle = color;
  ctx.lineWidth = 2.5;
  ctx.lineJoin = 'round';
  ctx.beginPath();
  let first = true;
  for (let px = 0; px < w; px++) {
    const z = xMin + (px / w) * (xMax - xMin);
    let y = fn(z);
    y = Math.max(yMin, Math.min(yMax, y));
    const py = toY(y);
    if (first) { ctx.moveTo(px, py); first = false; }
    else ctx.lineTo(px, py);
  }
  ctx.stroke();
}

function buildCards(filter) {
  const grid = document.getElementById('grid');
  grid.innerHTML = '';

  const filtered = filter === 'all' ? fns : fns.filter(f => f.category === filter);

  filtered.forEach((f, i) => {
    const card = document.createElement('div');
    card.className = 'card';
    card.style.animationDelay = (i * 0.04) + 's';
    card.innerHTML = `
      <div class="card-header">
        <div class="fn-name">${f.name}</div>
        <div class="fn-range">${f.range}</div>
      </div>
      <div class="fn-formula">${f.formula}</div>
      <canvas id="c${i}"></canvas>
      <div class="fn-desc">${f.desc}</div>
      <span class="fn-use">${f.use}</span>
    `;
    grid.appendChild(card);

    requestAnimationFrame(() => {
      const canvas = document.getElementById('c' + i);
      if (canvas) drawCurve(canvas, f.fn, f.color);
    });
  });
}

document.querySelectorAll('.filter-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    buildCards(btn.dataset.filter);
  });
});

buildCards('all');

window.addEventListener('resize', () => {
  const active = document.querySelector('.filter-btn.active');
  buildCards(active ? active.dataset.filter : 'all');
});
</script>
