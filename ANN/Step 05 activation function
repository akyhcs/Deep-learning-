const fns = [
  // Classic
  {
    name: "Step",
    formula: "f(z) = 1 if z≥0 else 0",
    range: "[0, 1]",
    category: "classic",
    use: "Original perceptron",
    desc: "Binary threshold — not differentiable, so cannot be used with backprop. Historical significance only.",
    color: "#7f8c8d",
    fn: z => z >= 0 ? 1 : 0
  },
  {
    name: "Sigmoid",
    formula: "f(z) = 1 / (1 + e⁻ᶻ)",
    range: "(0, 1)",
    category: "classic",
    use: "Binary classification output",
    desc: "Classic S-curve. Outputs interpretable as probability. Suffers from vanishing gradients at extremes.",
    color: "#2980b9",
    fn: z => 1 / (1 + Math.exp(-z))
  },
  {
    name: "Tanh",
    formula: "f(z) = (eᶻ − e⁻ᶻ) / (eᶻ + e⁻ᶻ)",
