    <div class="section-tag">Nonlinearity</div>
  </div>
  <div class="card">
    <div class="card-grid">
      <div class="formula-block">
        <div class="formula-label">Sigmoid</div>
        \[ \sigma(z) = \frac{1}{1+e^{-z}} \]
        <div class="formula-note" style="text-align:center">Range (0,1) · binary output</div>
      </div>
      <div class="formula-block">
        <div class="formula-label">Tanh</div>
        \[ \tanh(z) = \frac{e^z - e^{-z}}{e^z + e^{-z}} \]
        <div class="formula-note" style="text-align:center">Range (−1,1) · zero-centered</div>
      </div>
      <div class="formula-block">
        <div class="formula-label">ReLU</div>
        \[ f(z) = \max(0,\, z) \]
        <div class="formula-note" style="text-align:center">Range [0,∞) · default hidden layer</div>
      </div>
      <div class="formula-block">
        <div class="formula-label">Softmax (multi-class output)</div>
        \[ f(z_i) = \frac{e^{z_i}}{\sum_j e^{z_j}} \]
        <div class="formula-note" style="text-align:center">Outputs sum to 1 · probability dist.</div>
