  </div>
  <div class="card">
    <div class="card-grid">
      <div class="formula-block">
        <div class="formula-label">Expanded form</div>
        \[ \hat{y} = \sigma\!\left(x_0 w_0 + \sum_{i=1}^{m} x_i w_i\right) \]
        <div class="formula-note">
          <div class="note-row"><div class="note-dot" style="background:var(--cyan)"></div><div>x₀ = 1 always (bias trick)</div></div>
          <div class="note-row"><div class="note-dot" style="background:var(--orange)"></div><div>w₀ = bias weight</div></div>
        </div>
      </div>
      <div>
        <div class="formula-block" style="margin-bottom:12px">
          <div class="formula-label">Vector form</div>
          \[ \hat{y} = \sigma(w_0 + \mathbf{x}^T\mathbf{w}) \]
        </div>
        <div class="formula-block">
          <div class="formula-label">Compact — bias absorbed</div>
          \[ \hat{y} = \sigma(\tilde{\mathbf{x}}^T\mathbf{w}) \]
          <div class="formula-note" style="text-align:center">Prepend 1 to x, w₀ to w → single dot product</div>
        </div>
      </div>
    </div>
  </div>
</div>

